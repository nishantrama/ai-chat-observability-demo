# =============================================================================
#  AI Chat Observability Demo — configuration
# =============================================================================

# --- Anthropic ---
# OPTIONAL. Leave blank to run fully offline against the built-in mock server
# (no key, no network, no cost — still emits real gen_ai telemetry).
ANTHROPIC_API_KEY=

# --- Mock mode ---
# Force the local mock Anthropic API on/off. If unset, mock turns ON
# automatically whenever ANTHROPIC_API_KEY is blank.
MOCK_ANTHROPIC=true
MOCK_PORT=8080

# Model the chat app REQUESTS. The gateway may override it based on the prompt.
CHAT_MODEL=claude-opus-4-8
MID_MODEL=claude-sonnet-5
CHEAP_MODEL=claude-haiku-4-5-20251001

# --- AI Gateway ---
# The chat service routes every model call through the gateway.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8090
# ROUTER_MODE: "smart" routes by prompt (mitigates #3); "passthrough" always
# honors the requested model (reproduces the original always-Opus behaviour).
ROUTER_MODE=smart
GATEWAY_SERVICE_NAME=ai-gateway

# --- OpenTelemetry export to Dynatrace ---
# Dynatrace OTLP endpoint. Example:
#   https://<env-id>.live.dynatrace.com/api/v2/otlp
# Leave blank to fall back to console exporter (spans printed to stdout).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Dynatrace API token (scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest)
# Set as a full header value, e.g.  Authorization=Api-Token dt0c01.XXXX
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ai-chat-observability-demo

# --- Chaos / problem toggles (0.0 - 1.0) ---
# Probability a request injects extra latency (simulates slow model / no timeout).
CHAOS_LATENCY=0.25
# Probability a request triggers a real API error (bad model) -> error spans / 5xx.
CHAOS_ERROR=0.15
# Probability a request hammers the API to provoke 429 rate-limit errors.
CHAOS_RATE_LIMIT=0.10

# --- Gateway-layer problem toggles (see PROBLEMS.md, G1–G6) ---
GATEWAY_CACHE_ENABLED=true      # G1: broken response cache that never hits
GATEWAY_MAX_RETRIES=3           # G2: retry storm — retries with no backoff
GATEWAY_FALLBACK_ENABLED=true   # G3: silent fallback to the cheapest model
GATEWAY_MISROUTE_RATE=0.15      # G4: flaky classifier picks the wrong tier
GATEWAY_ROUTE_LATENCY_MS=60     # G5: routing overhead added before each LLM call
GATEWAY_ENFORCE_SAFETY=false    # G6: false = detect-but-don't-enforce (the problem)
