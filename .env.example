# =============================================================================
#  AI Chat Observability Demo — configuration
# =============================================================================

# --- Anthropic ---
# Required for real LLM calls. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model used for the "expensive" main chat path. Opus is intentionally used
# even for trivial prompts (see PROBLEMS.md — anti-pattern #3).
CHAT_MODEL=claude-opus-4-8
# A cheaper model exists but the demo deliberately does NOT route to it.
CHEAP_MODEL=claude-haiku-4-5-20251001

# --- OpenTelemetry export to Dynatrace ---
# Dynatrace OTLP endpoint. Example:
#   https://<env-id>.live.dynatrace.com/api/v2/otlp
# Leave blank to fall back to console exporter (spans printed to stdout).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Dynatrace API token (scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest)
# Set as a full header value, e.g.  Authorization=Api-Token dt0c01.XXXX
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ai-chat-observability-demo

# --- Chaos / problem toggles (0.0 - 1.0) ---
# Probability a request injects extra latency (simulates slow model / no timeout).
CHAOS_LATENCY=0.25
# Probability a request triggers a real API error (bad model) -> error spans / 5xx.
CHAOS_ERROR=0.15
# Probability a request hammers the API to provoke 429 rate-limit errors.
CHAOS_RATE_LIMIT=0.10
