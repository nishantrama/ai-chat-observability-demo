{
  "schemaId": "builtin:davis.anomaly-detectors",
  "scope": "environment",
  "value": {
    "enabled": true,
    "title": "Problem #2/#7 \u00b7 AI cost spike (oversized prompt / fan-out)",
    "description": "Estimated LLM spend per minute crossed the threshold \u2014 likely the huge system prompt or the 4-calls-per-turn fan-out.",
    "source": "AI Chat Observability Demo",
    "executionSettings": {
      "queryOffset": 1
    },
    "analyzer": {
      "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer",
      "input": [
        {
          "key": "query",
          "value": "timeseries cost = sum(gen_ai.client.estimated_cost.usd), interval:1m"
        },
        {
          "key": "slidingWindow",
          "value": "5"
        },
        {
          "key": "violatingSamples",
          "value": "3"
        },
        {
          "key": "dealertingSamples",
          "value": "5"
        },
        {
          "key": "alertCondition",
          "value": "ABOVE"
        },
        {
          "key": "alertOnMissingData",
          "value": "false"
        },
        {
          "key": "threshold",
          "value": "0.5"
        }
      ]
    },
    "eventTemplate": {
      "properties": [
        {
          "key": "event.type",
          "value": "CUSTOM_ALERT"
        },
        {
          "key": "event.name",
          "value": "Problem #2/#7 \u00b7 AI cost spike (oversized prompt / fan-out)"
        },
        {
          "key": "event.description",
          "value": "Estimated LLM spend per minute crossed the threshold \u2014 likely the huge system prompt or the 4-calls-per-turn fan-out.\n\nThreshold: {threshold}, condition: {alert_condition}."
        }
      ]
    }
  }
}