{
  "schemaId": "builtin:davis.anomaly-detectors",
  "scope": "environment",
  "value": {
    "enabled": true,
    "title": "Problem G2 \u00b7 Gateway retry storm (no backoff)",
    "description": "Gateway upstream retries per minute is high \u2014 retries with no backoff amplify load and cost.",
    "source": "AI Chat Observability Demo",
    "executionSettings": {
      "queryOffset": 1
    },
    "analyzer": {
      "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer",
      "input": [
        {
          "key": "query",
          "value": "timeseries retries = sum(gateway.upstream.retries), interval:1m"
        },
        {
          "key": "slidingWindow",
          "value": "5"
        },
        {
          "key": "violatingSamples",
          "value": "3"
        },
        {
          "key": "dealertingSamples",
          "value": "5"
        },
        {
          "key": "alertCondition",
          "value": "ABOVE"
        },
        {
          "key": "alertOnMissingData",
          "value": "false"
        },
        {
          "key": "threshold",
          "value": "5"
        }
      ]
    },
    "eventTemplate": {
      "properties": [
        {
          "key": "event.type",
          "value": "CUSTOM_ALERT"
        },
        {
          "key": "event.name",
          "value": "Problem G2 \u00b7 Gateway retry storm (no backoff)"
        },
        {
          "key": "event.description",
          "value": "Gateway upstream retries per minute is high \u2014 retries with no backoff amplify load and cost.\n\nThreshold: {threshold}, condition: {alert_condition}."
        }
      ]
    }
  }
}