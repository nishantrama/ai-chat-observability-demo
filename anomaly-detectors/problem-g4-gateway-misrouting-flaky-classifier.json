{
  "schemaId": "builtin:davis.anomaly-detectors",
  "scope": "environment",
  "value": {
    "enabled": true,
    "title": "Problem G4 \u00b7 Gateway misrouting (flaky classifier)",
    "description": "The gateway routed calls to the wrong model tier (misrouted) above the acceptable rate.",
    "source": "AI Chat Observability Demo",
    "executionSettings": {
      "queryOffset": 1
    },
    "analyzer": {
      "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer",
      "input": [
        {
          "key": "query",
          "value": "timeseries misroutes = sum(gateway.routing.decisions), filter:{gateway.route.misrouted == \"True\"}, interval:1m"
        },
        {
          "key": "slidingWindow",
          "value": "5"
        },
        {
          "key": "violatingSamples",
          "value": "3"
        },
        {
          "key": "dealertingSamples",
          "value": "5"
        },
        {
          "key": "alertCondition",
          "value": "ABOVE"
        },
        {
          "key": "alertOnMissingData",
          "value": "false"
        },
        {
          "key": "threshold",
          "value": "2"
        }
      ]
    },
    "eventTemplate": {
      "properties": [
        {
          "key": "event.type",
          "value": "CUSTOM_ALERT"
        },
        {
          "key": "event.name",
          "value": "Problem G4 \u00b7 Gateway misrouting (flaky classifier)"
        },
        {
          "key": "event.description",
          "value": "The gateway routed calls to the wrong model tier (misrouted) above the acceptable rate.\n\nThreshold: {threshold}, condition: {alert_condition}."
        }
      ]
    }
  }
}