    "8": {
      "type": "data",
      "title": "Failed LLM calls",
      "query": "fetch spans | filter isNotNull(gen_ai.request.model) and span.status_code == \"ERROR\" | summarize failed = count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "failed",
          "autoscale": true
        },
