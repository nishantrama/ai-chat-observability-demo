    "12": {
      "type": "data",
      "title": "Cache lookups by result (G1 \u2014 always miss)",
      "query": "timeseries lookups = sum(gateway.cache.lookups), by:{gateway.cache.hit}, interval:1m",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
