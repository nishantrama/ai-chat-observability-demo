{
  "version": 10,
  "variables": [],
  "tiles": {
    "0": {
      "type": "markdown",
      "title": "",
      "content": "# \ud83c\udfe6 Executive View\nBusiness outcomes at a glance \u2014 **spend**, **reliability**, and **volume** across the AI chat app and gateway."
    },
    "1": {
      "type": "data",
      "title": "Total estimated LLM spend (USD)",
      "query": "timeseries spend = sum(gen_ai.client.estimated_cost.usd)",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "USD spend",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "2": {
      "type": "data",
      "title": "LLM success rate (%)",
      "query": "fetch spans | filter isNotNull(gen_ai.request.model) | summarize total = count(), ok = countIf(span.status_code != \"ERROR\") | fieldsAdd success_rate_pct = (toDouble(ok) / total) * 100 | fields success_rate_pct",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "success %",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "3": {
      "type": "data",
      "title": "Chat turns handled",
      "query": "fetch spans | filter span.name == \"chat.turn\" | summarize turns = count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "turns",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "4": {
      "type": "data",
      "title": "LLM calls made",
      "query": "fetch spans | filter isNotNull(gen_ai.request.model) | summarize llm_calls = count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "calls",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "5": {
      "type": "data",
      "title": "Spend over time by model",
      "query": "timeseries spend = sum(gen_ai.client.estimated_cost.usd), by:{gen_ai.request.model}, interval:1m",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "6": {
      "type": "data",
      "title": "Cost by model (total USD)",
      "query": "timeseries spend = sum(gen_ai.client.estimated_cost.usd), by:{gen_ai.request.model} | fieldsAdd total_usd = arraySum(spend) | fields model = gen_ai.request.model, total_usd | sort total_usd desc",
      "visualization": "table",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "7": {
      "type": "data",
      "title": "Total tokens consumed",
      "query": "fetch logs | filter isNotNull(gen_ai.usage.total_tokens) | summarize tokens = sum(gen_ai.usage.total_tokens)",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "tokens",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
