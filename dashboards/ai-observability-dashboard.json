    "9": {
      "type": "markdown",
      "title": "",
      "content": "# \ud83d\udcca Director / VP View\nEfficiency & governance \u2014 **model strategy**, **cost drivers**, **routing quality**, and **safety posture**."
    },
    "10": {
      "type": "data",
      "title": "Model distribution (most popular model)",
      "query": "timeseries decisions = sum(gateway.routing.decisions), by:{gateway.model.selected} | fieldsAdd total = arraySum(decisions) | fields model = gateway.model.selected, total | sort total desc",
      "visualization": "barChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "11": {
      "type": "data",
      "title": "Cost by call type (fan-out driver)",
      "query": "timeseries spend = sum(gen_ai.client.estimated_cost.usd), by:{llm.call_kind} | fieldsAdd total_usd = arraySum(spend) | fields call_kind = llm.call_kind, total_usd | sort total_usd desc",
      "visualization": "table",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
