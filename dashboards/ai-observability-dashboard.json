    "13": {
      "type": "data",
      "title": "Routing: misrouted vs correct (G4)",
      "query": "timeseries decisions = sum(gateway.routing.decisions), by:{gateway.route.misrouted} | fieldsAdd total = arraySum(decisions) | fields misrouted = gateway.route.misrouted, total | sort total desc",
      "visualization": "barChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "14": {
      "type": "data",
      "title": "Safety: flagged vs enforced (G6 \u2014 detect\u2260enforce)",
      "query": "fetch spans | filter span.name == \"gateway.route\" | summarize routes = count(), flagged = countIf(gateway.safety.flagged == true), enforced = countIf(gateway.safety.enforced == true)",
      "visualization": "table",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "15": {
      "type": "data",
      "title": "LLM calls per chat turn (fan-out #7)",
      "query": "fetch spans | summarize turns = countIf(span.name == \"chat.turn\"), calls = countIf(isNotNull(gen_ai.request.model)) | fieldsAdd calls_per_turn = toDouble(calls) / turns | fields calls_per_turn",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "calls/turn",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "16": {
      "type": "data",
      "title": "Cache hit ratio % (G1 \u2192 ~0)",
      "query": "fetch spans | filter span.name == \"gateway.cache_lookup\" | summarize total = count(), hits = countIf(gateway.cache.hit == true) | fieldsAdd hit_ratio_pct = (toDouble(hits) / total) * 100 | fields hit_ratio_pct",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "cache hit %",
          "autoscale": true
        },
        "table": {
          "enableLineWrap": true,
          "hiddenColumns": [],
          "lineWrapIds": []
        }
      }
    },
    "17": {
      "type": "data",
      "title": "Misroute rate %",
      "query": "fetch spans | filter span.name == \"gateway.route\" | summarize total = count(), misrouted = countIf(gateway.route.misrouted == true) | fieldsAdd misroute_pct = (toDouble(misrouted) / total) * 100 | fields misroute_pct",
      "visualization": "singleValue",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
